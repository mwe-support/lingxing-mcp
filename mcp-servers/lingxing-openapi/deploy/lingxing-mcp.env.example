LINGXING_APP_ID=replace-me
LINGXING_APP_SECRET=replace-me
LINGXING_TOKEN_CACHE_FILE=/var/lib/lingxing-mcp/token_cache.json
# 单令牌与多人令牌二选一；团队共享推荐用 LINGXING_MCP_TOKENS_FILE。
LINGXING_MCP_BEARER_TOKEN=replace-me
LINGXING_MCP_TOKENS_FILE=/etc/lingxing-mcp/tokens.json
LINGXING_MCP_HOST=127.0.0.1
LINGXING_MCP_PORT=8099
PYTHONUNBUFFERED=1

# Optional role-to-tools JSON override. Built-in roles: minimal, operations, finance.
# Role allowlists are the visibility boundary; every role always includes lingxing_health_check, lingxing_smoke_check, and lingxing_rate_limit_policy.
# Omit this variable to use built-in role defaults.
# LINGXING_MCP_ROLE_TOOLS={"finance":["lingxing_finance_report_asin","lingxing_profit_seller"]}
# OpenAPI endpoint rate limiting.
LINGXING_OPENAPI_RATE_LIMIT_ENABLED=1
LINGXING_OPENAPI_RATE_LIMIT_DEFAULT_RPS=1
LINGXING_OPENAPI_RATE_LIMIT_DEFAULT_BURST=1
LINGXING_OPENAPI_RATE_LIMIT_WAIT_TIMEOUT=60
LINGXING_OPENAPI_RATE_LIMIT_OVERRIDES=/bd/profit/report/open/report/asin/list=10:10
